#!/bin/bash
set -euo pipefail

CONFIG="/etc/boghche/config.json"
DEFAULT_LANS='["192.168.0.0/16","172.16.0.0/16","172.18.0.0/16"]'

source /usr/local/lib/boghche/dashboard.sh || true

need_root() {
  if [ "${EUID}" -ne 0 ]; then
    echo "Please run with sudo: sudo boghche"
    exit 1
  fi
}

ask() {
  local label="$1"
  local default="${2:-}"
  if [ -n "$default" ]; then
    gum input --value "$default" --placeholder "$label"
  else
    gum input --placeholder "$label"
  fi
}

ask_password() {
  gum input --password --placeholder "$1"
}

yn() {
  gum confirm "$1" && echo true || echo false
}

configure() {
  need_root
  clear

  MODE_CHOICE=$(gum choose "Route-based VPN / VTI" "Policy-based VPN")
  [ "$MODE_CHOICE" = "Route-based VPN / VTI" ] && MODE="route" || MODE="policy"

  CONN_NAME=$(ask "Connection name" "fgt")
  LEFT_ID=$(ask "Local public IP / leftid")
  LEFT_IP=$(ask "Local public IP / left" "$LEFT_ID")
  RIGHT_IP=$(ask "Remote peer public IP / right")
  RIGHT_ID=$(ask "Remote peer ID / rightid" "$RIGHT_IP")
  PSK=$(ask_password "Pre-shared key / PSK")

  WAN_IF=$(ask "WAN interface" "eth0")
  NAT=$(yn "Enable NAT/MASQUERADE?")

  VTI_IF="vti0"
  VTI_ADDR="10.11.11.2/30"
  VTI_REMOTE="10.11.11.1"
  VTI_MARK="42"
  MTU="1480"
  ROUTE_SUBNETS="[]"

  if [ "$MODE" = "route" ]; then
    VTI_IF=$(ask "VTI interface name" "$VTI_IF")
    VTI_ADDR=$(ask "VTI local address with CIDR" "$VTI_ADDR")
    VTI_REMOTE=$(ask "VTI remote gateway address" "$VTI_REMOTE")
    VTI_MARK=$(ask "VTI mark/key" "$VTI_MARK")
    MTU=$(ask "VTI MTU" "$MTU")
  fi

  UNBOUND="false"
  UNBOUND_LISTEN_IP=""
  DNS_UPSTREAMS='[]'

  if [ "$MODE" = "route" ]; then
    UNBOUND=$(yn "Configure Unbound DNS-over-TLS on the VTI IP?")

    if [ "$UNBOUND" = "true" ]; then
      DEFAULT_VTI_IP="${VTI_ADDR%%/*}"
      UNBOUND_LISTEN_IP=$(ask "Unbound listen IP" "$DEFAULT_VTI_IP")
      PRIMARY_DNS=$(ask "Primary DoT upstream" "8.8.8.8@853#dns.google")
      SECONDARY_DNS=$(ask "Secondary DoT upstream" "8.8.4.4@853#dns.google")
      DNS_UPSTREAMS=$(jq -cn --arg p "$PRIMARY_DNS" --arg s "$SECONDARY_DNS" '[ $p, $s ]')
    fi
  fi

  mkdir -p /etc/boghche

  jq -n \
    --arg mode "$MODE" \
    --arg conn_name "$CONN_NAME" \
    --arg left "$LEFT_IP" \
    --arg leftid "$LEFT_ID" \
    --arg right "$RIGHT_IP" \
    --arg rightid "$RIGHT_ID" \
    --arg psk "$PSK" \
    --arg wan_if "$WAN_IF" \
    --arg nat "$NAT" \
    --arg vti_if "$VTI_IF" \
    --arg vti_addr "$VTI_ADDR" \
    --arg vti_remote "$VTI_REMOTE" \
    --arg vti_mark "$VTI_MARK" \
    --arg mtu "$MTU" \
    --arg unbound "$UNBOUND" \
    --arg unbound_listen_ip "$UNBOUND_LISTEN_IP" \
    --argjson dns_upstreams "$DNS_UPSTREAMS" \
    --argjson default_lans "$DEFAULT_LANS" \
    '{mode:$mode,conn_name:$conn_name,left:$left,leftid:$leftid,right:$right,rightid:$rightid,psk:$psk,wan_if:$wan_if,nat:($nat=="true"),vti_if:$vti_if,vti_addr:$vti_addr,vti_remote:$vti_remote,vti_mark:$vti_mark,mtu:$mtu,default_lans:$default_lans,unbound:($unbound=="true"),unbound_listen_ip:$unbound_listen_ip,dns_upstreams:$dns_upstreams}' > "$CONFIG"

  chmod 600 "$CONFIG"
  gum style --foreground 46 "✔ Configuration saved"
}

generate_ipsec() {
  /usr/local/lib/boghche/ipsec.sh
}

start_tunnel() {
  generate_ipsec
  systemctl restart boghche || true
  ipsec restart || true
  sleep 5
  systemctl restart boghche || true
  gum style --foreground 46 "✔ Tunnel started"
}

stop_tunnel() {
  systemctl stop boghche || true
  ipsec stop || true
}

while true; do
  render_dashboard

  ACTION=$(gum input --placeholder "Select option number")

  case "$ACTION" in
    1) configure ;;
    2) start_tunnel ;;
    3) stop_tunnel ;;
    4)
      clear
      ipsec statusall || true
      echo
      ip -s xfrm state || true
      ;;
    5)
      ROUTE=$(gum input --placeholder "Subnet route")
      [ -n "$ROUTE" ] && gum style --foreground 46 "✔ Route queued: $ROUTE"
      ;;
    6)
      SRC=$(gum input --placeholder "Source subnet")
      PORT=$(gum input --placeholder "Port")
      [ -n "$SRC" ] && [ -n "$PORT" ] && ufw allow from "$SRC" to any port "$PORT"
      ;;
    7)
      clear
      systemctl status boghche --no-pager || true
      ;;
    8)
      clear
      jq . "$CONFIG" 2>/dev/null || echo "No config"
      ;;
    9) exit 0 ;;
  esac

  gum confirm "Return to dashboard?" || exit 0
done
